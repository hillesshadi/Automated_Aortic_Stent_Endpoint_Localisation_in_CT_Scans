# STEP 1 — DICOM Loading
# ═══════════════════════════════════════════════════════════════════════════════
def load_dicom(dicom_dir: str):
    """Load DICOM → (volume_hu[Z,Y,X], spacing, origin, ct_date, z_phys)."""
    logger.info("  [1-load] %s", dicom_dir)
    ct_date = "N/A"
    for fname in sorted(os.listdir(dicom_dir)):
        fp = os.path.join(dicom_dir, fname)
        if not os.path.isfile(fp):
            continue
        try:
            ds = pydicom.dcmread(fp, stop_before_pixels=True)
            for tag in ("AcquisitionDate", "StudyDate", "SeriesDate"):
                raw = getattr(ds, tag, None)
                if raw and len(str(raw)) == 8:
                    ct_date = f"{raw[:4]}-{raw[4:6]}-{raw[6:]}"
                    break
            break
        except Exception:
            continue

    reader = sitk.ImageSeriesReader()
    files = reader.GetGDCMSeriesFileNames(dicom_dir)
    if not files:
        raise FileNotFoundError(f"No DICOM series in: {dicom_dir}")
    reader.SetFileNames(files)
    img = reader.Execute()
    spacing = img.GetSpacing()
    origin = img.GetOrigin()
    vol = sitk.GetArrayFromImage(img).astype(np.int16)
    z_phys = np.array([origin[2] + i * spacing[2] for i in range(vol.shape[0])])
    logger.info("  [1-load] shape=%s spacing=(%.2f,%.2f,%.2f) Z=[%.1f,%.1f]",
                vol.shape, *spacing, z_phys.min(), z_phys.max())
    return vol, spacing, origin, ct_date, z_phys, img

