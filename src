def discover_datasets(data_root):
    datasets = []
    root = Path(data_root)
    for entry in sorted(root.iterdir()):
        if not entry.is_dir(): continue
        if FOLDER_RE.match(entry.name):
            datasets.append((entry.name, str(entry))); continue
        for sub in sorted(entry.iterdir()):
            if sub.is_dir():
                datasets.append((f"{entry.name}-{sub.name}", str(sub)))
    if not datasets:
        raise FileNotFoundError(f"No datasets under {data_root}")
    logger.info("  Discovered %d datasets", len(datasets))
    return datasets

def _load_annotations(path):
    if not path or not os.path.exists(path): return {}
    try:
        df = pd.read_csv(path)
        df.columns = [c.lower().strip() for c in df.columns]
        return {str(r.get("case_id","")).strip(): {
            "start":[float(r["start_x"]),float(r["start_y"]),float(r["start_z"])],
            "end":[float(r["end_x"]),float(r["end_y"]),float(r["end_z"])]}
            for _,r in df.iterrows() if str(r.get("case_id","")).strip()}
    except Exception:
        return {}

