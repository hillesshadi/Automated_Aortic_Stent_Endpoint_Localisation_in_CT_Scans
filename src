def run_batch(data_root, xlsx_path, workers=4, annotations=None):
    datasets = discover_datasets(data_root)
    annotations = annotations or {}
    args_list = [(cid, ddir, xlsx_path, annotations.get(cid))
                 for cid, ddir in datasets]
    results = []
    logger.info("  Batch: %d datasets, %d workers", len(args_list), workers)
    if workers == 1:
        for a in args_list:
            results.append(process_patient(a))
    else:
        with ProcessPoolExecutor(max_workers=workers) as ex:
            futs = {ex.submit(process_patient, a): a[0] for a in args_list}
            for f in as_completed(futs):
                try: results.append(f.result())
                except Exception as e: logger.error("  %s: %s", futs[f], e)

    ok = sum(1 for r in results if r.get("status")=="OK")
    wr = sum(1 for r in results if "WARN" in str(r.get("status","")))
    er = sum(1 for r in results if "ERROR" in str(r.get("status","")))
    logger.info("\n  ════ BATCH COMPLETE ════  Total=%d OK=%d WARN=%d ERROR=%d", len(results),ok,wr,er)
    for label, key in [("start", "start_err"), ("end", "end_err")]:
        vals = [r[key] for r in results if r.get(key) is not None]
        if vals:
            logger.info("  Mean %s error: %.2f mm (n=%d)", label, np.mean(vals), len(vals))
    return results

