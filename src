# ═══════════════════════════════════════════════════════════════════════════════
# Per-patient pipeline
# ═══════════════════════════════════════════════════════════════════════════════
def _empty(cid, ct="N/A"):
    return {k: None for k in ["start_x","start_y","start_z","end_x","end_y","end_z",
            "mid_x","mid_y","mid_z","length_mm","slices_detected","mean_ring_score",
            "start_err","end_err"]} | {"case_id":cid,"ct_date":ct,"seg_method":"","status":"ERROR"}

def process_patient(args_tuple):
    case_id, dicom_dir, xlsx_path, annot = args_tuple
    result = _empty(case_id)
    try:
        logger.info("\n━━━ %s ━━━", case_id)

        # Step 1
        vol, spacing, origin, ct_date, z_phys, sitk_img = load_dicom(dicom_dir)
        result["ct_date"] = ct_date

        # Step 2
        lumen, seg_method = segment_aorta(vol, spacing, sitk_img, dicom_dir)
        result["seg_method"] = seg_method
        del sitk_img
        if not lumen.any():
            result["status"] = "WARN: aorta empty"
            save_to_excel(result, xlsx_path); return result

        # Step 3
        rois = extract_aorta_roi(lumen, spacing)
        if len(rois) < 10:
            result["status"] = "WARN: too few aorta slices"
            save_to_excel(result, xlsx_path); return result

        # Step 4
        candidates = extract_candidates(vol, lumen, rois, spacing)
        del lumen; gc.collect()
        if len(candidates) < MIN_STENT_SLICES:
            result["status"] = "WARN: too few candidates"
            save_to_excel(result, xlsx_path); return result

        # Step 5+7 — per-slice ring detection + classification
        scores_raw, ring_info = classify_slices(vol, rois, candidates, spacing)
        del vol; gc.collect()

        # Step 6 — 3D cylindrical consistency
        scores_cyl = cylindrical_consistency(scores_raw, ring_info, rois, spacing)

        # Step 8 — gap bridging & smoothing
        scores_smooth, classified = smooth_and_bridge(scores_cyl)

        region = find_stent_region(classified)
        if region is None:
            result["status"] = "WARN: no stent region"
            save_to_excel(result, xlsx_path); return result

        start_z, end_z = region

        # Steps 9+10 — world coordinates
        start_mm, end_mm, mid_mm, length = compute_world_endpoints(
            start_z, end_z, rois, ring_info, spacing, origin, z_phys)

        n_det = int(classified[start_z:end_z+1].sum())
        stent_scores = scores_smooth[start_z:end_z+1]
        mean_sc = float(np.mean(stent_scores)) if len(stent_scores) > 0 else 0

        result.update({
            "start_x": round(float(start_mm[0]),3), "start_y": round(float(start_mm[1]),3),
            "start_z": round(float(start_mm[2]),3),
            "end_x": round(float(end_mm[0]),3), "end_y": round(float(end_mm[1]),3),
            "end_z": round(float(end_mm[2]),3),
            "mid_x": round(float(mid_mm[0]),3), "mid_y": round(float(mid_mm[1]),3),
            "mid_z": round(float(mid_mm[2]),3),
            "length_mm": round(length,2), "slices_detected": n_det,
            "mean_ring_score": round(mean_sc,3), "status": "OK",
        })

        # Validation
        if annot:
            try:
                ms = np.array(annot["start"], dtype=float)
                me = np.array(annot["end"], dtype=float)
                if ms[2] < me[2]: ms, me = me, ms
                result["start_err"] = round(float(np.linalg.norm(start_mm - ms)), 2)
                result["end_err"]   = round(float(np.linalg.norm(end_mm   - me)), 2)
                logger.info("  [eval] err: start=%.2f end=%.2f mm",
                           result["start_err"], result["end_err"])
            except Exception as e:
                logger.warning("  [eval] %s", e)

        logger.info("  [done] %s len=%.1f slices=%d score=%.3f seg=%s",
                    case_id, length, n_det, mean_sc, seg_method)

    except Exception:
        result["status"] = f"ERROR: {traceback.format_exc(limit=3)}"
        logger.error("  [FAIL] %s\n%s", case_id, traceback.format_exc())

    save_to_excel(result, xlsx_path)
    return result

