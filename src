# STEP 2 — Deep Learning Aorta Segmentation
# ═══════════════════════════════════════════════════════════════════════════════
def _ball(r):
    g = np.mgrid[-r:r+1, -r:r+1, -r:r+1]
    return (g[0]**2 + g[1]**2 + g[2]**2) <= r**2

def segment_aorta_totalseg(sitk_img, dicom_dir):
    """Use TotalSegmentator (nnU-Net) for aorta segmentation."""
    logger.info("  [2-seg] Using TotalSegmentator (nnU-Net) ...")
    with tempfile.TemporaryDirectory() as tmpdir:
        nii_in = os.path.join(tmpdir, "input.nii.gz")
        out_dir = os.path.join(tmpdir, "segmentations")
        sitk.WriteImage(sitk_img, nii_in)

        cmd = ["TotalSegmentator", "-i", nii_in, "-o", out_dir, "--fast",
               "--roi_subset", "aorta"]
        try:
            subprocess.run(cmd, check=True, capture_output=True, timeout=600)
        except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired) as e:
            logger.warning("  [2-seg] TotalSegmentator failed: %s", e)
            return None

        # Look for aorta segmentation file
        for name in ["aorta.nii.gz", "aorta_ascending.nii.gz"]:
            seg_path = os.path.join(out_dir, name)
            if os.path.exists(seg_path):
                seg_img = sitk.ReadImage(seg_path)
                mask = sitk.GetArrayFromImage(seg_img).astype(bool)
                logger.info("  [2-seg] TotalSegmentator: %d aorta voxels", int(mask.sum()))
                return mask

        # If roi_subset didn't work, try combined output
        combined = os.path.join(out_dir, "total.nii.gz")
        if os.path.exists(combined):
            seg_img = sitk.ReadImage(combined)
            arr = sitk.GetArrayFromImage(seg_img)
            # Aorta label IDs in TotalSegmentator: 7 (asc), 8 (desc)
            mask = np.isin(arr, [7, 8])
            if mask.any():
                logger.info("  [2-seg] TotalSegmentator combined: %d aorta voxels", int(mask.sum()))
                return mask

    return None

def segment_aorta_threshold(volume_hu, spacing):
    """Fallback: multi-threshold + morphology aorta segmentation."""
    logger.info("  [2-seg] Fallback: multi-threshold segmentation ...")
    best_mask, best_score = None, -1e9
    sz_min = min(spacing)

    for hu_lo, hu_hi in [(80, 450), (100, 500), (150, 600), (50, 400)]:
        mask = (volume_hu.astype(np.int32) >= hu_lo) & (volume_hu.astype(np.int32) <= hu_hi)
        cr = max(1, min(3, int(round(4.0 / sz_min))))
        mask = binary_closing(mask, structure=_ball(cr))
        for z in range(mask.shape[0]):
            mask[z] = binary_fill_holes(mask[z])
        labeled, n = ndi_label(mask)
        if n == 0:
            continue
        sizes = np.array([(labeled == i).sum() for i in range(1, n + 1)])
        cc = (labeled == int(np.argmax(sizes)) + 1)
        z_ext = sum(1 for zz in range(cc.shape[0]) if cc[zz].any())
        body_frac = int(cc.sum()) / max(1, mask.size)
        score = z_ext * 1000 - abs(body_frac - 0.005) * 1e8
        if score > best_score:
            best_score = score
            best_mask = cc.astype(bool)

    if best_mask is not None:
        logger.info("  [2-seg] Fallback: %d aorta voxels", int(best_mask.sum()))
    return best_mask

def segment_aorta(volume_hu, spacing, sitk_img, dicom_dir):
    """Try nnU-Net/TotalSegmentator first, fall back to threshold."""
    seg_method = "threshold"
    mask = None

    if HAS_TOTALSEG:
        mask = segment_aorta_totalseg(sitk_img, dicom_dir)
        if mask is not None:
            seg_method = "TotalSegmentator"

    if mask is None:
        mask = segment_aorta_threshold(volume_hu, spacing)
        seg_method = "threshold"

    if mask is None or not mask.any():
        logger.warning("  [2-seg] Aorta segmentation failed entirely")
        return np.zeros(volume_hu.shape, dtype=bool), "FAILED"

    return mask, seg_method

