# CLI
# ═══════════════════════════════════════════════════════════════════════════════
def main():
    p = argparse.ArgumentParser(description="Ring-shape stent detection v2 (nnU-Net + 3D tracking)",
                                formatter_class=argparse.ArgumentDefaultsHelpFormatter)
    p.add_argument("--data_root", required=True)
    p.add_argument("--output", default="stent_ring_results_v2.xlsx")
    p.add_argument("--workers", type=int, default=None)
    p.add_argument("--annotations", default=None)
    p.add_argument("--use_builtin_annotations", action="store_true")
    p.add_argument("--sequential", action="store_true")
    args = p.parse_args()

    workers = 1 if args.sequential else (args.workers or max(1, os.cpu_count() or 4))
    annots = {}
    if args.use_builtin_annotations:
        annots.update(BUILTIN_ANNOTATIONS)
    if args.annotations:
        annots.update(_load_annotations(args.annotations))

    os.makedirs(os.path.dirname(os.path.abspath(args.output)) or ".", exist_ok=True)
    logger.info("=" * 60)
    logger.info("  Stent Ring Detector v2 (nnU-Net + 3D Cylindrical Tracking)")
    logger.info("  data_root: %s", args.data_root)
    logger.info("  output:    %s", args.output)
    logger.info("  workers:   %d", workers)
    logger.info("  TotalSeg:  %s", "AVAILABLE" if HAS_TOTALSEG else "not found (using threshold fallback)")
    logger.info("  OpenCV:    %s", "yes" if HAS_CV2 else "no (using skimage)")
    logger.info("=" * 60)
    run_batch(args.data_root, args.output, workers, annots)
    logger.info("Results: %s", args.output)

if __name__ == "__main__":
    main()
