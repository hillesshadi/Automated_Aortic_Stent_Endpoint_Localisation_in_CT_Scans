# STEP 3 — Aorta ROI Extraction (per-slice centroid + radius)
# ═══════════════════════════════════════════════════════════════════════════════
def extract_aorta_roi(lumen_mask, spacing):
    """Per-slice centroid (cy, cx) and radius_mm. Returns dict {z: (cy,cx,r_mm)}."""
    sx, sy = spacing[0], spacing[1]
    rois = {}
    for z in range(lumen_mask.shape[0]):
        sl = lumen_mask[z]
        if not sl.any():
            continue
        ys, xs = np.where(sl)
        cy, cx = float(ys.mean()), float(xs.mean())
        area_mm2 = float(sl.sum()) * sx * sy
        r_mm = float(np.sqrt(area_mm2 / np.pi))
        rois[z] = (cy, cx, r_mm)
    logger.info("  [3-roi] Aorta present in %d slices", len(rois))
    return rois

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 4 — Adaptive High-HU Candidate Extraction
# ═══════════════════════════════════════════════════════════════════════════════
def extract_candidates(volume_hu, lumen_mask, rois, spacing):
    """Per-slice high-HU binary within dilated aorta ROI. Returns {z: mask2d}."""
    sx, sy = spacing[0], spacing[1]
    dil_r = max(2, int(round(DILATION_MM / min(sx, sy))))
    struct_2d = np.ones((2*dil_r+1, 2*dil_r+1), dtype=bool)
    candidates = {}

    for z, (cy, cx, r_mm) in rois.items():
        sl_hu = volume_hu[z].astype(np.int32)
        search = binary_dilation(lumen_mask[z], structure=struct_2d)
        roi_vals = sl_hu[search]
        if len(roi_vals) == 0:
            continue
        p90 = float(np.percentile(roi_vals, 90))
        hu_min = max(HU_STENT_ADAPTIVE_FLOOR, int(p90 * 0.85))
        high = (sl_hu >= hu_min) & (sl_hu <= HU_STENT_MAX) & search
        if int(high.sum()) >= 8:
            candidates[z] = high.astype(np.uint8)
        else:
            # Try lower threshold
            med = (sl_hu >= max(350, int(p90 * 0.7))) & (sl_hu <= HU_STENT_MAX) & search
            if int(med.sum()) >= 8:
                candidates[z] = med.astype(np.uint8)

    logger.info("  [4-cand] Candidate slices: %d / %d", len(candidates), len(rois))
    return candidates

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 5 — Contour + Radial Ring Detection
# ═══════════════════════════════════════════════════════════════════════════════
def _fit_ellipse(pts_xy):
    """Fit ellipse. Returns ((cx,cy),(w,h),angle) or None."""
    if len(pts_xy) < 5:
        return None
    if HAS_CV2:
        try:
            return cv2.fitEllipse(pts_xy.astype(np.float32).reshape(-1, 1, 2))
        except Exception:
            pass
    try:
        from skimage.measure import EllipseModel
        model = EllipseModel()
        if model.estimate(pts_xy):
            xc, yc, a, b, theta = model.params
            return ((xc, yc), (2*a, 2*b), np.degrees(theta))
    except Exception:
        pass
    return None

def detect_ring_contour(cand_mask, cy_a, cx_a, r_mm, spacing):
    """Find ring contours via ellipse fitting. Returns list of ring dicts."""
    sx, sy = spacing[0], spacing[1]
    rings = []
    for contour in find_contours(cand_mask, level=0.5):
        if len(contour) < MIN_CONTOUR_PTS:
            continue
        pts_xy = contour[:, ::-1]
        ell = _fit_ellipse(pts_xy)
        if ell is None:
            continue
        (ecx, ecy), (ew, eh), _ = ell
        if ew < 1 or eh < 1:
            continue
        ew_mm, eh_mm = ew * sx, eh * sy
        mean_d = (ew_mm + eh_mm) / 2.0
        area = np.pi * (ew/2) * (eh/2)
        perim = np.pi * (3*(ew/2+eh/2) - np.sqrt((3*ew/2+eh/2)*(ew/2+3*eh/2)))
        circ = min((4*np.pi*area) / max(perim**2, 1), 1.0)
        ax_r = max(ew, eh) / max(min(ew, eh), 1)
        dist = np.sqrt((ecx - cx_a)**2 + (ecy - cy_a)**2) * min(sx, sy)
        closed = np.linalg.norm(contour[0] - contour[-1]) < max(5, len(contour)*0.1)
        rings.append({
            "cx": ecx, "cy": ecy, "diam_mm": mean_d,
            "circ": circ, "ax_ratio": ax_r, "dist_mm": dist,
            "closed": closed, "npts": len(contour),
            "w_mm": ew_mm, "h_mm": eh_mm,
        })
    return rings

def detect_ring_radial(cand_mask, cy_a, cx_a, spacing):
    """Radial profile completeness. Returns 0.0–1.0."""
    sx, sy = spacing[0], spacing[1]
    H, W = cand_mask.shape
    r_min = max(3, int(AORTA_DIAM_MIN_MM / 2 / min(sx, sy)))
    r_max = int(AORTA_DIAM_MAX_MM / 2 / min(sx, sy)) + 10
    angles = np.linspace(0, 2*np.pi, N_RADIAL_ANGLES, endpoint=False)
    peaks = []
    for a in angles:
        for r in range(r_min, min(r_max, max(H, W)//2)):
            y, x = int(round(cy_a + r*np.sin(a))), int(round(cx_a + r*np.cos(a)))
            if 0 <= y < H and 0 <= x < W and cand_mask[y, x] > 0:
                peaks.append(r)
                break
    if len(peaks) < 3:
        return 0.0
    med = np.median(peaks)
    tol = max(3, med * 0.3)
    return float(np.sum(np.abs(np.array(peaks) - med) <= tol)) / N_RADIAL_ANGLES

def score_slice(rings, radial, cy_a, cx_a, r_mm):
    """Composite ring score. Returns (score, best_ring)."""
    best_s, best_r = 0.0, None
    for rng in rings:
        s_c = min(rng["circ"] / 0.5, 1.0)
        s_a = max(0, 1 - abs(rng["ax_ratio"] - 1) / 2)
        s_d = max(0, 1 - rng["dist_mm"] / 20)
        s_sz = 1.0 if AORTA_DIAM_MIN_MM <= rng["diam_mm"] <= AORTA_DIAM_MAX_MM else max(0, 0.5)
        s_cl = 1.0 if rng["closed"] else 0.4
        s_n = min(rng["npts"] / 40, 1.0)
        s = 0.20*s_c + 0.15*s_a + 0.20*s_d + 0.15*s_sz + 0.15*s_cl + 0.15*s_n
        if s > best_s:
            best_s, best_r = s, rng
    return 0.55 * best_s + 0.45 * radial, best_r

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 6 — 3D Cylindrical Consistency Tracking
# ═══════════════════════════════════════════════════════════════════════════════
def cylindrical_consistency(
    scores_raw, ring_info, rois, spacing, window=CYLINDER_WINDOW
):
    """
    Enforce 3D consistency: a true stent forms a cylinder — consecutive slices
    should have rings at similar (cx, cy) positions and similar diameters.
    Penalize isolated detections that break the cylinder assumption.
    """
    nz = len(scores_raw)
    scores_out = scores_raw.copy()
    sz = spacing[2]
    sxy = min(spacing[0], spacing[1])

    # Collect ring centers and diameters
    centers = {}  # z -> (cx_mm, cy_mm, diam_mm)
    for z in range(nz):
        rng = ring_info.get(z)
        if rng is not None and "cx" in rng:
            centers[z] = (rng["cx"] * sxy, rng["cy"] * sxy, rng["diam_mm"])
        elif z in rois:
            cy, cx, r_mm = rois[z]
            centers[z] = (cx * sxy, cy * sxy, 2 * r_mm)

    # For each slice with a detection, check neighbours
    for z in range(nz):
        if scores_raw[z] < 0.1:
            continue
        if z not in centers:
            continue

        cx_z, cy_z, d_z = centers[z]
        consistent_count = 0
        check_count = 0

        for dz in range(-window, window + 1):
            zn = z + dz
            if dz == 0 or zn < 0 or zn >= nz or zn not in centers:
                continue
            check_count += 1
            cx_n, cy_n, d_n = centers[zn]

            # Check center drift
            drift = np.sqrt((cx_z - cx_n)**2 + (cy_z - cy_n)**2)
            # Check diameter consistency
            diam_diff = abs(d_z - d_n) / max(d_z, d_n, 1)

            if drift < CYLINDER_RADIUS_TOL_MM and diam_diff < CYLINDER_DIAM_TOL_FRAC:
                consistent_count += 1

        if check_count > 0:
            consistency = float(consistent_count) / float(check_count)
            # Boost scores with high cylindrical consistency, penalize outliers
            scores_out[z] *= (0.4 + 0.6 * consistency)

    logger.info("  [6-cyl] 3D cylindrical consistency applied (window=%d)", window)
    return scores_out

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 7 — Slice Classification
# ═══════════════════════════════════════════════════════════════════════════════
def classify_slices(volume_hu, rois, candidates, spacing):
    """Per-slice ring detection + scoring. Returns (scores, classified, ring_info)."""
    nz = volume_hu.shape[0]
    scores = np.zeros(nz)
    ring_info = {}
    for z in range(nz):
        if z not in rois or z not in candidates:
            ring_info[z] = None
            continue
        cy, cx, r_mm = rois[z]
        rings = detect_ring_contour(candidates[z], cy, cx, r_mm, spacing)
        radial = detect_ring_radial(candidates[z], cy, cx, spacing)
        sc, best = score_slice(rings, radial, cy, cx, r_mm)
        scores[z] = sc
        ring_info[z] = best
    return scores, ring_info

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 8 — Gap Bridging & Temporal Smoothing
# ═══════════════════════════════════════════════════════════════════════════════
def smooth_and_bridge(scores, gap=GAP_BRIDGE):
    """Median filter + Gaussian smooth + gap bridging."""
    nz = len(scores)
    if nz > 5:
        # Median filter to remove isolated spikes/drops
        s = ndi_median_filter(scores, size=5)
        # Light Gaussian smoothing along Z
        s = gaussian_filter1d(s, sigma=1.5)
    else:
        s = scores.copy()

    classified = (s >= MIN_RING_SCORE).astype(np.int32)

    # Bridge small gaps
    bridged = classified.copy()
    for i in range(nz):
        if bridged[i] == 0:
            left = max(0, i - gap)
            right = min(nz, i + gap + 1)
            has_l = np.any(classified[left:i] > 0) if i > 0 else False
            has_r = np.any(classified[i+1:right] > 0) if i < nz - 1 else False
            if has_l and has_r:
                bridged[i] = 1

    n_det = int(bridged.sum())
    logger.info("  [8-smooth] Stent slices after smoothing+bridging: %d / %d", n_det, nz)
    return s, bridged

def find_stent_region(classified):
    """Find longest contiguous stent run. Returns (start_z, end_z) or None."""
    nz = len(classified)
    runs, in_run, start = [], False, 0
    for i in range(nz):
        if classified[i] > 0 and not in_run:
            start, in_run = i, True
        elif classified[i] == 0 and in_run:
            runs.append((start, i - 1))
            in_run = False
    if in_run:
        runs.append((start, nz - 1))
    if not runs:
        return None
    runs.sort(key=lambda r: r[1] - r[0], reverse=True)
    best = runs[0]
    if best[1] - best[0] + 1 < MIN_STENT_SLICES:
        logger.warning("  [8-region] Run too short: %d < %d", best[1]-best[0]+1, MIN_STENT_SLICES)
        return None
    logger.info("  [8-region] Stent: slices %d–%d (%d)", best[0], best[1], best[1]-best[0]+1)
    return best

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 9+10 — Start/End/Midpoint + World Coordinates
# ═══════════════════════════════════════════════════════════════════════════════
def compute_world_endpoints(start_z, end_z, rois, ring_info, spacing, origin, z_phys):
    """Convert slice endpoints to world-mm coordinates."""
    sx, sy = spacing[0], spacing[1]
    ox, oy = origin[0], origin[1]

    def _xy_mm(z_sl):
        rng = ring_info.get(z_sl)
        if rng and "cx" in rng:
            return ox + rng["cx"] * sx, oy + rng["cy"] * sy
        if z_sl in rois:
            cy, cx, _ = rois[z_sl]
            return ox + cx * sx, oy + cy * sy
        for dz in range(1, 10):
            for zz in [z_sl - dz, z_sl + dz]:
                if zz in rois:
                    cy, cx, _ = rois[zz]
                    return ox + cx * sx, oy + cy * sy
        return ox, oy

    xs, ys = _xy_mm(start_z)
    xe, ye = _xy_mm(end_z)
    mid_z = (start_z + end_z) // 2
    xm, ym = _xy_mm(mid_z)

    start_mm = np.array([xs, ys, float(z_phys[start_z])])
    end_mm   = np.array([xe, ye, float(z_phys[end_z])])
    mid_mm   = np.array([xm, ym, float(z_phys[mid_z])])

    # Enforce orientation: start = cranial (highest Z)
    if start_mm[2] < end_mm[2]:
        start_mm, end_mm = end_mm.copy(), start_mm.copy()

    length = float(np.linalg.norm(end_mm - start_mm))
    return start_mm, end_mm, mid_mm, length

