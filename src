            hfl = PatternFill("solid", fgColor="1F4E79")
            ha = Alignment(horizontal="center", vertical="center", wrap_text=True)
            for col, h in enumerate(EXCEL_HEADERS, 1):
                c = ws.cell(row=1, column=col, value=h)
